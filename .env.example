# =============================================================================
# CafeProject Backend — VDS sablonu (PostgreSQL)
# =============================================================================
# Kurulum:
#   cp .env.example .env
#   nano .env          # DATABASE_URL, JWT_SECRET, OPS_PASSWORD duzenleyin
# veya:
#   npm run setup:env
#
# Sonra:
#   npm install
#   npm run db:migrate
#   npm start
# =============================================================================

PORT=5000
NODE_ENV=production

# Veritabani — sadece PostgreSQL kullanin
DB_PROVIDER=postgres
DATABASE_URL=postgresql://CafeProject:SIFRENIZ@localhost:5432/CafeProject
PG_SSL=false
SKIP_DB=false

JWT_SECRET=buraya-en-az-32-karakter-rastgele-guclu-bir-deger-yazin
JWT_EXPIRES_IN=7d

# Frontend / mobil adresiniz (virgulle birden fazla)
CORS_ORIGIN=http://89.35.73.3

RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
BODY_LIMIT=2mb

# Production'da false birakin (gercek odeme entegrasyonu gerekir)
ALLOW_MOCK_PAYMENTS=false

OPS_EMAIL=administor@gmmail.com
OPS_PASSWORD=guclu-ops-sifre-buraya

# --- Local gelistirme (VDS'te kullanmayin) ---
# NODE_ENV=development
# SKIP_DB=true
# CORS_ORIGIN=
