PORT=5000
NODE_ENV=development

# postgres (varsayilan) | mongodb (eski Atlas)
DB_PROVIDER=postgres

# PostgreSQL — gercek bilgilerinizi girin
DATABASE_URL=postgresql://CafeProject:my1234Test.@localhost:5432/CafeProject
# Uzak/cloud PostgreSQL icin SSL gerekebilir
PG_SSL=false

# MongoDB (sadece DB_PROVIDER=mongodb iken)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.6cz3ugh.mongodb.net/cafedb?retryWrites=true&w=majority
# Atlas Network Access'e IP ekleyin: npm run atlas:ip

# Veritabani baglanamazsa gecici true (local dev)
SKIP_DB=false

JWT_SECRET=cafe-project-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

CORS_ORIGIN=

RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
BODY_LIMIT=2mb
ALLOW_MOCK_PAYMENTS=false

OPS_EMAIL=administor@gmmail.com
OPS_PASSWORD=1234
